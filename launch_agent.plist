<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
macOS LaunchAgent: starts ga4-market-intelligence on user login (PC boot).
Install:
  cp launch_agent.plist ~/Library/LaunchAgents/cz.promogen.ga4intel.plist
  launchctl load ~/Library/LaunchAgents/cz.promogen.ga4intel.plist
Uninstall:
  launchctl unload ~/Library/LaunchAgents/cz.promogen.ga4intel.plist
  rm ~/Library/LaunchAgents/cz.promogen.ga4intel.plist
Logs:
  tail -f ~/Downloads/claude/ga4-market-intelligence/data/launchagent.log
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>cz.promogen.ga4intel</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/matusondrussek/Downloads/claude/ga4-market-intelligence/venv/bin/python3</string>
        <string>-u</string>
        <string>/Users/matusondrussek/Downloads/claude/ga4-market-intelligence/app.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/matusondrussek/Downloads/claude/ga4-market-intelligence</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/matusondrussek/Downloads/claude/ga4-market-intelligence/data/launchagent.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/matusondrussek/Downloads/claude/ga4-market-intelligence/data/launchagent.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
    </dict>

    <key>ThrottleInterval</key>
    <integer>30</integer>
</dict>
</plist>
